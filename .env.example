# ============================================================
# Configuration — Plateforme Décisionnelle de Suivi Académique
# ============================================================
# Copier ce fichier en .env puis adapter les valeurs.
#   cp .env.example .env

# --- PostgreSQL (Data Warehouse + modèles OLTP) ---
POSTGRES_DB=suivi_academique
POSTGRES_USER=suivi
POSTGRES_PASSWORD=suivi_dev
POSTGRES_PORT=5432

# Django lit cette variable (format URL unique)
DATABASE_URL=postgres://suivi:suivi_dev@localhost:5432/suivi_academique

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=changer-en-production-generer-une-cle-longue-aleatoire
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# --- Authentification JWT ---
# Durée de vie des jetons (minutes)
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# --- ETL / service.campusfaso.bf ---
# Mode de la source de données ETL : "mock" (fixtures locales) ou "api" (vrai endpoint lecture-seule)
ETL_SOURCE_MODE=mock
# Si ETL_SOURCE_MODE=api, indiquer l'URL de base et un éventuel jeton (lecture seule)
ETL_CAMPUSFASO_BASE_URL=https://service.campusfaso.bf
ETL_CAMPUSFASO_API_TOKEN=

# --- pgAdmin (optionnel) ---
PGADMIN_EMAIL=admin@suivi.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
